
/**
 * WebHunter Pro Security Rules - Hardened RBAC
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Returns true if the authenticated user has the SuperAdmin role
    function isSuperAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'SuperAdmin';
    }

    // --- COLLECTION RULES ---

    /**
     * @description System configuration and protocols.
     * Read by all admins, write ONLY by SuperAdmins.
     */
    match /system/{document=**} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    /**
     * @description Rules for Administrator profiles.
     */
    match /admins/{adminId} {
      allow get: if isOwner(adminId) || isSuperAdmin();
      allow list: if isSignedIn();
      allow create: if isSignedIn(); // Allow initial signup, but role logic is in app
      allow update: if isOwner(adminId) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    /**
     * @description Shared metadata lists.
     * Read by all authenticated users, write ONLY by SuperAdmins.
     */
    match /tlds/{tldId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
    match /countries/{countryId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    /**
     * @description Campaigns and nested data.
     * Enforces path-based ownership or SuperAdmin access.
     */
    match /admins/{adminId}/campaigns/{campaignId} {
      allow get, list: if isOwner(adminId) || isSuperAdmin();
      allow create: if isOwner(adminId) || isSuperAdmin();
      allow update, delete: if isOwner(adminId) || isSuperAdmin();

      match /runs/{runId} {
        allow read, write: if isOwner(adminId) || isSuperAdmin();

        match /domains/{domainId} {
          allow read, write: if isOwner(adminId) || isSuperAdmin();

          match /emails/{emailId} {
            allow read, write: if isOwner(adminId) || isSuperAdmin();
          }
        }
      }
    }

    match /admins/{adminId}/notifications/{notificationId} {
      allow read, write: if isOwner(adminId) || isSuperAdmin();
    }

    match /admins/{adminId}/exportJobs/{jobId} {
      allow read, write: if isOwner(adminId) || isSuperAdmin();
    }
  }
}
