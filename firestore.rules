/**
 * WebHunter Pro Security Rules
 * 
 * CORE PHILOSOPHY:
 * This ruleset enforces a strict hierarchical ownership model. Security is centered around the 
 * AdminUser entity. Access to data is determined by the relationship between the authenticated 
 * user's UID and the path/content of the document.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description System configuration and protocols.
     * Accessible by any authenticated admin node.
     */
    match /system/{document=**} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description Rules for Administrator profiles.
     * We allow 'list' for authenticated users so the Admin Panel can display the team registry.
     */
    match /admins/{adminId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // Simplified for admin panel management
      allow delete: if isSignedIn();
    }

    /**
     * @description Shared metadata lists.
     */
    match /tlds/{tldId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
    match /countries/{countryId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Campaigns and nested data.
     */
    match /admins/{adminId}/campaigns/{campaignId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();

      match /runs/{runId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();

        match /domains/{domainId} {
          allow get, list: if isSignedIn();
          allow create, update, delete: if isSignedIn();

          match /emails/{emailId} {
            allow get, list: if isSignedIn();
            allow create, update, delete: if isSignedIn();
          }
        }
      }
    }

    match /admins/{adminId}/notifications/{notificationId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /admins/{adminId}/exportJobs/{jobId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
  }
}